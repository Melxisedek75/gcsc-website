{
  "name": "gcsctoken111",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build:token":    "npx proton-asc gcsctoken111.contract.ts",
    "build:member":   "npx proton-asc gcscmember11.contract.ts",
    "build:lead":     "npx proton-asc gcsclead1111.contract.ts",
    "build:stake":    "npx proton-asc gcscstake111.contract.ts",
    "build:treasury": "npx proton-asc gcsctreasry1.contract.ts",
    "build:realty":   "npx proton-asc gcscrealty11.contract.ts",
    "build:insure":   "npx proton-asc gcscinsure11.contract.ts",
    "build": "npm-run-all build:token build:member build:lead build:stake build:treasury build:realty build:insure",
    "playground": "npm run build:token && cross-env LOG_LEVEL=debug ts-node ./playground.ts"
  },
  "dependencies": {
    "proton-tsc": "latest"
  },
  "engines": {
    "npm": ">=7.0.0",
    "node": ">=16.0.0"
  },
  "engineStrict": true,
  "devDependencies": {
    "@greymass/abi2core": "^1.1.0",
    "@greymass/eosio": "^0.5.5",
    "@proton/cli": "^0.1.74",
    "@proton/js": "^26.1.2",
    "@proton/vert": "^0.3.18",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.1.0",
    "@types/node": "^17.0.22",
    "chai": "^4.3.6",
    "cross-env": "^7.0.3",
    "cross-fetch": "^3.1.5",
    "globby": "^10",
    "mocha": "^9.2.2",
    "npm-run-all": "^4.1.5",
    "ts-node": "^10.7.0",
    "ts-morph": "^14.0.0",
    "typescript": "^4.6.2"
  }
}
